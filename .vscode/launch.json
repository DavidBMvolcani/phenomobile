{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Phenomobile Merge",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "train",
                "--dataset",
                "Anthocyanin_with_rgb_051225-050226.csv",
                "--features",
                "valPlantMean,satPlantMean,huePlantMean,Anthocyanin_OD_530_nm",
                "--target",
                "Anthocyanin_OD_530_nm"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}